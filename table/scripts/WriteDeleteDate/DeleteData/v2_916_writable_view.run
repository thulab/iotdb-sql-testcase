device_id string tag,
s1 int32 field
);
insert into t_alter_time_column_type_default_src(time,region,device_id,s1) values
(1779933600000,'north','d1',1),
(1779933601000,'south','d2',2);
create writable view t_alter_time_column_type_default_view as
select region, device_id, s1 from t_alter_time_column_type_default_src
with (schema_cascade=true, ttl='INF');
flush;
<<NULL;
alter table t_alter_time_column_type_default_view alter column time set data type string;
<<SQLSTATE;
drop view t_alter_time_column_type_default_view;
drop table t_alter_time_column_type_default_src;
<<SQLSTATE;

