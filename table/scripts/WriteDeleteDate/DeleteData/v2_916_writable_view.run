create table t_non_time_column_named_time_src(
region string tag,
time int32 field,
device_id string tag,
s1 string field
);
<<SQLSTATE;

-- 10. 显式自定义 TIME 列存在时，其他非 TIME 列名叫 time：通过可写视图正常读写
create table t_custom_time_with_field_named_time_src(
region string tag,
d_datetime timestamp time,
device_id string tag,
time blob field,
s1 int32 field
);
insert into t_custom_time_with_field_named_time_src(region,d_datetime,device_id,time,s1) values
('north',1779933600000,'d1','aa',1),
('north',1779933601000,'d2',null,2),
('south',1779933602000,'d3','cc',3);
create writable view t_custom_time_with_field_named_time_view as
select region, device_id, time, s1 from t_custom_time_with_field_named_time_src
with (schema_cascade=false, ttl='INF');
flush;
<<NULL;
select count(*) as total_rows_field_named_time from t_custom_time_with_field_named_time_view;
select d_datetime,region,device_id,cast(time as string),s1 from t_custom_time_with_field_named_time_view order by d_datetime;
select count(*) as null_field_named_time_rows from t_custom_time_with_field_named_time_view where time is null;
delete from t_custom_time_with_field_named_time_view where d_datetime >= 1779933601000 and d_datetime <= 1779933602000;
select count(*) as total_rows_after_custom_time_delete from t_custom_time_with_field_named_time_view;
select count(*) as deleted_rows_after_custom_time_delete from t_custom_time_with_field_named_time_view where d_datetime >= 1779933601000 and d_datetime <= 1779933602000;
drop view t_custom_time_with_field_named_time_view;
drop table t_custom_time_with_field_named_time_src;

-- 11. 可写视图中，普通列重命名为 time 应报错
create table t_rename_field_to_time_src(
region string tag,
d_datetime timestamp time,
device_id string tag,
blob_col blob field,
s1 int32 field
);
insert into t_rename_field_to_time_src(region,d_datetime,device_id,blob_col,s1) values
('north',1779933600000,'d1','aa',1),
('south',1779933601000,'d2',null,2);
create writable view t_rename_field_to_time_view as
select region, device_id, blob_col, s1 from t_rename_field_to_time_src
with (schema_cascade=false, ttl='INF');
flush;
<<NULL;
alter table t_rename_field_to_time_view rename column blob_col to time;
select d_datetime,region,device_id,cast(time as string),s1 from t_rename_field_to_time_view order by d_datetime;
drop view t_rename_field_to_time_view;
drop table t_rename_field_to_time_src;

