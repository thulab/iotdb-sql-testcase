drop table t_alter_time_column_type_custom_src;
<<SQLSTATE;

-- 16. 自定义 TIME 列的查询场景：通过可写视图执行 WHERE 组合条件、GROUP BY/HAVING、OFFSET/LIMIT
create table t_select_custom_time_src(
region string tag,
event_ts timestamp time,
device_id string tag,
s1 int32 field,
s2 double field,
status boolean field,
note string field
);
insert into t_select_custom_time_src(region,event_ts,device_id,s1,s2,status,note) values
('north',1779933600000,'d1',10,1.5,true,'a'),
('north',1779933601000,'d1',20,2.5,false,null),
('north',1779933602000,'d2',30,3.5,true,'c'),
('south',1779933603000,'d2',40,4.5,false,'d'),
('south',1779933604000,'d3',50,null,true,null);
create writable view t_select_custom_time_view as
select region, device_id, s1, s2, status, note from t_select_custom_time_src
with (schema_cascade=false, ttl='INF');
flush;
<<NULL;
select event_ts,region,device_id,s1,status,note
from t_select_custom_time_view
where event_ts >= 1779933601000 and event_ts <= 1779933603000
  and (region='north' or device_id='d2')
order by event_ts;
select count(*) as matched_rows_with_field_and_tag
from t_select_custom_time_view
where event_ts >= 1779933601000 and event_ts <= 1779933604000
  and (region='north' or status = true);
select device_id, count(*) as cnt, avg(s1) as avg_s1
from t_select_custom_time_view
where event_ts >= 1779933600000 and event_ts <= 1779933603000
group by device_id
having count(*) >= 2
order by device_id;
select event_ts,device_id,s1
from t_select_custom_time_view
order by event_ts
offset 1
limit 2;
select event_ts,device_id,s2
from t_select_custom_time_view
order by s2 desc nulls last, event_ts
limit 5;
select event_ts,device_id,s1
from t_select_custom_time_view
order by event_ts desc nulls last
limit 2;
select date_bin(2s, event_ts) as bucket_ts, count(*) as cnt, avg(s1) as avg_s1
from t_select_custom_time_view
group by 1
order by bucket_ts;
select date_bin(2s, event_ts) as bucket_ts, count(*) as cnt
from t_select_custom_time_view
group by 1
having count(*) >= 2
order by bucket_ts;
drop view t_select_custom_time_view;
drop table t_select_custom_time_src;

drop database if exists v2_916_writable_view;
<<NULL;
