-- =====================================================
-- 用例 12：插入 null → 预期成功
-- =====================================================
connect root/TimechoDB@2021;

drop database if exists test;
create database test;
use test;
CREATE TABLE table1(device_id STRING TAG, s1 OBJECT FIELD);

INSERT INTO table1(time, device_id, s1) VALUES (1704067210000, 'test_device', null);
select s1 from table1 where time=1704067210000;

-- 清理
drop table table1;
<<NULL;
drop database test;
<<NULL;




-- =====================================================
-- 用例 13：大小写不敏感（d1 vs D1）→ 两条记录
-- =====================================================
connect root/TimechoDB@2021;

drop database if exists test;
create database test;
use test;
CREATE TABLE table1(device_id STRING TAG, s1 OBJECT FIELD);

INSERT INTO table1(time, device_id, s1) VALUES (1704067209000, 'd1',to_object(true, 0, X'696F746462'));
INSERT INTO table1(time, device_id, s1) VALUES (1704067209000, 'D1',to_object(true, 0, X'696F746462'));
select time, device_id, s1 from table1 order by time, device_id;

-- 清理
drop table table1;
<<NULL;
drop database test;
<<NULL;




-- =====================================================
-- 用例 14：多行写入 → 预期成功
-- =====================================================
connect root/TimechoDB@2021;

drop database if exists test;
create database test;
use test;
CREATE TABLE table1(device_id STRING TAG, s1 OBJECT FIELD);

INSERT INTO table1(time, device_id, s1) VALUES 
(1704067209000, 'd1', to_object(true, 0, X'696F746462')),
(1704067209000, 'D1', to_object(true, 0, X'696F746462')),
(1704067210000, 'd1', to_object(true, 0, X'7465737464617461'));
select time, device_id, s1 from table1 order by time, device_id;

-- 清理
drop table table1;
<<NULL;
drop database test;
<<NULL;


-- =====================================================
-- 用例 15：单次完整写入 → 预期成功
-- =====================================================
connect root/TimechoDB@2021;

drop database if exists test;
create database test;
use test;
CREATE TABLE table1(device_id STRING TAG, s1 OBJECT FIELD);

insert into table1(device_id, s1) values('tag1', to_object(true, 0, X'696F746462'));
select * from table1 where device_id='tag1';

-- 清理
drop table table1;
<<NULL;
drop database test;
<<NULL;




-- =====================================================
-- 用例 16：分段写入（isEOF=false）→ 预期成功
-- =====================================================
connect root/TimechoDB@2021;

drop database if exists test;
create database test;
use test;
CREATE TABLE table1(device_id STRING TAG, s1 OBJECT FIELD);

insert into table1(time, device_id, s1) values(1, 'tag1', to_object(false, 0, X'696F'));
insert into table1(time, device_id, s1) values(1, 'tag1', to_object(false, 2, X'7464'));
insert into table1(time, device_id, s1) values(1, 'tag1', to_object(true, 4, X'62'));
select s1 from table1 where time=1;

-- 清理
drop table table1;
<<NULL;
drop database test;
<<NULL;




-- =====================================================
-- 用例 17：同主键覆盖写入 → 后写胜出
-- =====================================================
connect root/TimechoDB@2021;

drop database if exists test;
create database test;
use test;
CREATE TABLE table1(device_id STRING TAG, s1 OBJECT FIELD);

INSERT INTO table1(time, device_id, s1) VALUES (1704067210002,'d1', to_object(true, 0, X'696F746468'));
INSERT INTO table1(time, device_id, s1) VALUES (1704067210002,'d1', to_object(true, 0, X'696F746952'));
select s1 from table1 where time=1704067210002;

-- 清理
drop table table1;
<<NULL;
drop database test;
<<NULL;




-- =====================================================
-- 用例 18：写入 0 字节内容 → 预期成功
-- =====================================================
connect root/TimechoDB@2021;

drop database if exists test;
create database test;
use test;
CREATE TABLE table1(device_id STRING TAG, s1 OBJECT FIELD);

insert into table1(time, device_id, s1) values(now(), 'tag1', to_object(true, 0, X''));
select s1 from table1 where device_id='tag1';

-- 清理
drop table table1;
<<NULL;
drop database test;
<<NULL;




