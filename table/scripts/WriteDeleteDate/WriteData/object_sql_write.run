-- =====================================================
-- 用例 1：未使用 to_object 函数插入数据 → 预期报错
-- =====================================================
connect root/TimechoDB@2021;

-- 完整前置条件
drop database if exists test;
create database test;
use test;
CREATE TABLE table1(device_id STRING TAG, s1 OBJECT FIELD);

-- 步骤
INSERT INTO table1(time, device_id, s1) VALUES (1704067200000, 'test_device', (true, 0, X'696F746462'));
<<SQLSTATE;

-- 清理
drop table table1;
<<NULL;
drop database test;
<<NULL;




