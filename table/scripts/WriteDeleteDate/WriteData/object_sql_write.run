-- =====================================================
-- 用例 21：只写部分 Object（isEOF=false）→ 查询可见但 size=0
-- =====================================================
connect root/TimechoDB@2021;

drop database if exists test;
create database test;
use test;
CREATE TABLE table1(device_id STRING TAG, s1 OBJECT FIELD);

insert into table1(time, device_id, s1) values(1, 'tag1', to_object(false, 0, X'696F'));
select s1 from table1 where time=1;

-- 清理
drop table table1;
<<NULL;
drop database test;
<<NULL;




-- =====================================================
-- 用例 22：offset ≠ 已写入大小 → 预期失败
-- =====================================================
connect root/TimechoDB@2021;

drop database if exists test;
create database test;
use test;
CREATE TABLE table1(device_id STRING TAG, s1 OBJECT FIELD);

insert into table1(time, device_id, s1) values(1, 'tag1', to_object(false, 0, X'696F'));
insert into table1(time, device_id, s1) values(1, 'tag1', to_object(false, 3, X'7464'));
<<SQLSTATE;

drop table table1;
<<NULL;
drop database test;
<<NULL;




-- =====================================================
-- 用例 23：offset=0 & isEOF=true → 后写覆盖，查询只剩第二次
-- =====================================================
connect root/TimechoDB@2021;

drop database if exists test;
create database test;
use test;
CREATE TABLE table1(device_id STRING TAG, s1 OBJECT FIELD);

insert into table1(time, device_id, s1) values(1, 'tag1', to_object(false, 0, X'696F'));
insert into table1(time, device_id, s1) values(1, 'tag1', to_object(true, 0, X'7465'));
select s1 from table1 where time=1;

-- 清理
drop table table1;
<<NULL;
drop database test;
<<NULL;




