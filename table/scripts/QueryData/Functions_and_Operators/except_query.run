--17. 数据类型OBJECT 不支持EXCEPT
select object_1 from t1
except
select object_1 from t2;
<<SQLSTATE;

--18. 列数不匹配
select device_id, int32_1, float_1 from t1
except
select device_id, int32_1 from t2;
<<SQLSTATE;

select device_id, int32_1 from t1
except
select device_id, int32_1, float_1 from t2;
<<SQLSTATE;

--19. EXCEPT执行多列
select device_id, int32_1, int64_1, double_1, float_1, boolean_1, text_1, string_1, date_1, timestamp_1, blob_1 from t1
except
select device_id, int32_1, int64_1, double_1, float_1, boolean_1, text_1, string_1, date_1, timestamp_1, blob_1 from t2
except
select device_id, int32_1, int64_1, double_1, float_1, boolean_1, text_1, string_1, date_1, timestamp_1, blob_1 from t3
order by 1, 2, 3, 4;

--20. 子查询作为EXCEPT操作数
select * from (select device_id, int32_1 from t1 where int32_1 > 200) result_1
except
select * from (select device_id, int32_1 from t1 where int32_1 > 300) result_2
order by 1, 2;

select device_id, sum_val from (
	select device_id, sum(int32_1) as sum_val from t1 group by device_id
) as sub_t1
except
select device_id, sum_val from (
    select device_id, sum(int32_1) as sum_val from t2 group by device_id
) as sub_t2
order by device_id;

select * from t1
where int32_1 NOT IN (
    select int32_1 from t2
    except
    select int32_1 from t3
)
order by time;

--21. 带聚合函数COUNT的EXCEPT
select device_id, count(*) as count_result1 from t1 group by device_id 
except
select device_id, count(*) as count_result2 from t2 group by device_id
order by device_id;

--22. 含NULL支持的EXCEPT:NULL值被视为相等的
select text_1, string_1 from t1
except
select text_1, string_1 from t2
order by 1,2;

--23. 相同的EXCEPT
select device_id from t1 
except
select device_id from t1 
except
select device_id from t1
order by device_id;


-- 清理数据
connect root/TimechoDB@2021;
drop database test_db;
<<NULL;
