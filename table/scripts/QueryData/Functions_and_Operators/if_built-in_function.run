-- ============================================================
-- 用例 7: IF 与 CASE 等价性验证
-- ============================================================
connect root/TimechoDB@2021;
drop database test;
<<NULL;

-- 前置条件：创建表并插入测试数据

-- 创建并使用数据库
create database test;
use test;

CREATE TABLE test.if_test(
    ts TIMESTAMP,
    col_boolean BOOLEAN,
    col_int32 INT32,
    col_int64 INT64,
    col_float FLOAT,
    col_double DOUBLE,
    col_text TEXT,
    col_string STRING,
    col_blob BLOB,
    col_timestamp TIMESTAMP,
    col_date DATE
);

INSERT INTO test.if_test(ts, col_boolean, col_int32, col_int64, col_float, col_double, col_text, col_string) 
VALUES (now(), true, 1, 100, 1.5, 2.5, 'text1', 'string1');

INSERT INTO test.if_test(ts, col_boolean, col_int32, col_int64, col_float, col_double, col_text, col_string) 
VALUES (now()+1s, false, 0, 0, 0.0, 0.0, '', '');

INSERT INTO test.if_test(ts, col_boolean, col_int32, col_int64, col_float, col_double, col_text, col_string) 
VALUES (now()+2s, true, -1, -100, -1.5, -2.5, 'text3', 'string3'); 

INSERT INTO test.if_test(ts, col_boolean, col_int32, col_int64, col_float, col_double, col_text, col_string) 
VALUES (now()+3s, NULL, NULL, NULL, NULL, NULL, NULL, NULL);

-- 测试步骤
SELECT
   col_int32 AS original_value,
   if(col_int32 > 0, 'Y', 'N') AS if_func_result,
   CASE WHEN col_int32 > 0 THEN 'Y' ELSE 'N' END AS case_when_result
 FROM test.if_test;

-- 清理环境
drop database test;
<<NULL;

