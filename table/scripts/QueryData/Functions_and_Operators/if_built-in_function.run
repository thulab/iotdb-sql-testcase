<<NULL;

-- 创建并使用数据库
create database test;
use test;

CREATE TABLE test.if_test(
    ts TIMESTAMP,
    col_boolean BOOLEAN,
    col_int32 INT32
);
INSERT INTO test.if_test(ts, col_boolean, col_int32) VALUES (now(), true, 1);
INSERT INTO test.if_test(ts, col_boolean, col_int32) VALUES (now()+1s, false, 0);

-- 创建用户并授权
create user user1 '@Pass1234567';
grant select on any to user user1;

-- 使用新用户执行 IF 查询
connect user1/@Pass1234567;
-- 切换用户后需要使用数据库
use test;
SELECT if(col_boolean = true, 'YES') FROM test.if_test WHERE col_boolean = true;

-- 清理环境
connect root/TimechoDB@2021;
drop user user1;
<<NULL;
drop database test;
<<NULL;

