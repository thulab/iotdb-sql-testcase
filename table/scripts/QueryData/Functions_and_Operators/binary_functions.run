-- 二进制函数和运算符测试用例
-- IoTDB 2.0.8.1
-- 生成时间: 2026-04-13
-- 编写人: 小泽的钳子
-- ============================================================

-- ============================================================
-- 用例 1: TO_BASE64 编码 STRING 类型 (P0)
-- ============================================================
connect root/TimechoDB@2021;
drop database test;
<<NULL;

create database test;
use test;

CREATE TABLE test.binary_test(ts TIMESTAMP, col_string STRING);

INSERT INTO test.binary_test VALUES (NOW(), NOW(), 'hello');

SELECT to_base64(col_string) FROM test.binary_test;

drop database test;
<<NULL;

-- ============================================================
-- 用例 2: TO_BASE64 编码 TEXT 类型 (P0)
-- ============================================================
