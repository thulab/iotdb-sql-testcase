	smooth => 0.5,
	threshold => 10.0,
	width => 1000.0, 
	height => 500.0,
	smooth_on_pattern => false
) order by 1,2,3,4;

--6.3.5 数据类型：BOOLEAN 【不支持】
select * from pattern_match(
	data => (select time, boolean_1 from t1 order by time),
	time_col => 'time',
	data_col => 'boolean_1',
	pattern => 'false,true,true',
	smooth => 0.5,
	threshold => 10.0,
	width => 1000.0, 
	height => 500.0,
	smooth_on_pattern => false
) order by 1,2,3,4;
<<SQLSTATE;

--6.3.6 数据类型：TEXT 【不支持】
select * from pattern_match(
	data => (select time, text_1 from t1 order by time),
