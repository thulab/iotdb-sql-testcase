	threshold => 10.0, 
	width => 1000.0, 
	height => 500.0, 
	smooth_On_Pattern=> false
)order by 1,2,3;

--6.4.5 无效的pattern格式
select * from pattern_match(
     data => t1,
     time_col => 'time',
     data_col => 'int32_1',
     pattern => 'abc,def,ghi',
     smooth => 0.5,
     threshold => 10.0,
     width => 1000.0,
     height => 500.0,
     smooth_on_pattern => false
 );
<<SQLSTATE;

--6.5 参数smooth：必填项，非负实数(≥ 0)
--6.5.1 smooth为空
select * from pattern_match(
	data => t1, 
	time_col => 'time', 
	data_col => 'int32_1',
	pattern => '1, 2, 1',
	threshold => 10.0, 
	width => 1000.0, 
	height => 500.0, 
	smooth_On_Pattern=> false
)order by 1,2,3;
<<SQLSTATE;

--6.5.2 smooth为0或0.0：无平滑
select * from pattern_match(
	data => t1, 
	time_col => 'time', 
	data_col => 'int32_1',
	pattern => '1, 2, 1',
	smooth => 0, 
	threshold => 10.0, 
	width => 1000.0, 
	height => 500.0, 
	smooth_On_Pattern=> false
)order by 1,2,3;
<<SQLSTATE;

select * from pattern_match(
	data => t1, 
	time_col => 'time', 
	data_col => 'int32_1',
	pattern => '1, 2, 1',
	smooth => 0.0, 
	threshold => 10.0, 
	width => 1000.0, 
	height => 500.0, 
	smooth_On_Pattern=> false
)order by 1,2,3;

--6.5.3 smooth为负数
select * from pattern_match(
   data => t1,
   time_col => 'time',
   data_col => 'int32_1',
   pattern => '1, 2, 1',
   smooth => -0.5,
   threshold => 10.0,
   width => 1000.0,
   height => 500.0,
   smooth_On_Pattern=> false
 )order by 1,2,3;
<<SQLSTATE;
 
--6.5.4 smooth:低平滑度0.1
select * from pattern_match(
    data => t1,
    time_col => 'time',
    data_col => 'int32_1',
    pattern => '1,2,1,1,1',
    smooth => 0.1,
    threshold => 10.0,
    width => 1000.0,
    height => 500.0,
    smooth_on_pattern => false
)order by 1,2,3;

--6.5.4 smooth:高平滑度0.9
select * from pattern_match(
    data => t1,
    time_col => 'time',
    data_col => 'int32_1',
    pattern => '1,2,1,1,1',
    smooth => 0.9,
    threshold => 10.0,
    width => 1000.0,
    height => 500.0,
    smooth_on_pattern => false
)order by 1,2,3;

--6.5.5 smooth:最大平滑1
select * from pattern_match(
    data => t1,
    time_col => 'time',
    data_col => 'int32_1',
    pattern => '1,2,1',
    smooth => 1.0,
    threshold => 10.0,
    width => 1000.0,
    height => 500.0,
    smooth_on_pattern => false
)order by 1,2,3;

--6.5.6 smooth:2
select * from pattern_match(
    data => t1,
    time_col => 'time',
    data_col => 'int32_1',
    pattern => '1,2,1',
    smooth => 2.0,
    threshold => 10.0,
    width => 1000.0,
    height => 500.0,
    smooth_on_pattern => false
)order by 1,2,3;

--6.6 参数threshold：必填项，非负实数(≥ 0)
--6.6.1 threshold为空
select * from pattern_match(
	data => t1, 
	time_col => 'time', 
	data_col => 'int32_1',
	pattern => '1, 2, 1',
	smooth => 0.0,  
	width => 1000.0, 
	height => 500.0, 
	smooth_On_Pattern=> false
)order by 1,2,3;
<<SQLSTATE;

--6.6.2 threshold为0或0.0
select * from pattern_match(
	data => t1, 
	time_col => 'time', 
	data_col => 'int32_1',
	pattern => '1, 2, 1',
	smooth => 0.5, 
	threshold => 0, 
	width => 1000.0, 
	height => 500.0, 
	smooth_On_Pattern=> false
)order by 1,2,3;
<<SQLSTATE;

select * from pattern_match(
	data => t1, 
	time_col => 'time', 
	data_col => 'int32_1',
	pattern => '1, 2, 1',
	smooth => 0.5, 
	threshold => 0.0, 
	width => 1000.0, 
	height => 500.0, 
	smooth_On_Pattern=> false
)order by 1,2,3;

--6.6.3 threshold为负数
select * from pattern_match(
   data => t1,
   time_col => 'time',
   data_col => 'int32_1',
   pattern => '1, 2, 1',
   smooth => 0.5,
   threshold => -1.1,
   width => 1000.0,
   height => 500.0,
   smooth_On_Pattern=> false
 )order by 1,2,3;
<<SQLSTATE;
 
--6.6.4 threshold为1.0
select * from pattern_match(
    data => t1,
    time_col => 'time',
    data_col => 'int32_1',
    pattern => '1,2,3,2,1,1,1,1,1',
    smooth => 0.5,
    threshold => 1.0,
    width => 1000.0,
    height => 500.0,
    smooth_on_pattern => false
)order by 1,2,3;

