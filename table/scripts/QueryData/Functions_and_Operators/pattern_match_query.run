--6.9 参数smooth_on_pattern：选填，false 或true
--6.9.1 smooth_on_pattern为空
select * from pattern_match(
    data => t1,
    time_col => 'time',
    data_col => 'int32_1',
    pattern => '1,2,3,2,1,1,1,1,1,1',
    smooth => 0.5,
    threshold => 10.0,
    width => 100.0,
    height => 500.0
)order by 1,2,3;

--6.9.2 smooth_on_pattern为false：不对pattern进行平滑
select * from pattern_match(
    data => t1,
    time_col => 'time',
    data_col => 'int32_1',
    pattern => '1,2,3,2,1,1,1,1,1,1',
    smooth => 0.5,
    threshold => 10.0,
    width => 100.0,
    height => 500.0,
	smooth_on_pattern => false
)order by 1,2,3;

--6.9.3 smooth_on_pattern为true：对pattern进行平滑处理后再匹配
select * from pattern_match(
    data => t1,
    time_col => 'time',
    data_col => 'int32_1',
    pattern => '1,2,3,2,1,1,1,1,1,1',
    smooth => 0.5,
    threshold => 10.0,
    width => 100.0,
    height => 500.0,
	smooth_on_pattern => true
)order by 1,2,3;

--6.10 正则查询:+ | *
--6.10.1 {pattern}+ 表示匹配1次或多次
select * from pattern_match(
    data => t1,
    time_col => 'time',
    data_col => 'int32_1',
    pattern => '1,{2,3,2}+,1,1,1,1,1',
    smooth => 0.5,
    threshold => 100.0,
    width => 1000.0,
    height => 500.0,
    smooth_on_pattern => false
)order by 1,2,3;

--6.10.2 {pattern}* 表示匹配0次或多次
select * from pattern_match(
    data => t1,
    time_col => 'time',
    data_col => 'int32_1',
    pattern => '1,1.0,{1,2,3,2}*,1,1,1,1,1',
    smooth => 0.5,
    threshold => 100.0,
    width => 1000.0,
    height => 500.0,
    smooth_on_pattern => false
) order by 1,2,3;

--6.10.3 复杂通配符组合测试
select * from pattern_match(
    data => t1,
    time_col => 'time',
    data_col => 'int32_1',
    pattern => '{1}+,{2,3}*,{1}+',
    smooth => 0.5,
    threshold => 50.0,
    width => 1000.0,
    height => 500.0,
    smooth_on_pattern => false
);

--7. 按设备分区的pattern匹配
select * from pattern_match(
     data => t1 PARTITION BY device_id ORDER BY time,
     time_col => 'time',
     data_col => 'double_1',
     pattern => '1.1,1.1,1.1,2.1,2.1,2.1,2.1',
     smooth => 0.5,
     threshold => 10.0,
     width => 1000.0,
     height => 500.0,
     smooth_on_pattern => false
 )order by 1,2,3;

