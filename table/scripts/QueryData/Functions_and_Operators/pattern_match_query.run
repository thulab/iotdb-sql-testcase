// 时间序列趋势匹配表值函数
// 新增patter_match内置表值函数完成相似度匹配的筛选
// data参数为必填项
// time_col 参数为可选项
// data_col 参数为必填项
// pattern参数为必填项
// smooth为必填项
// threshold为必填项
// width 选填项
// height选填项
// smooth_on_pattern为选填项

connect root/TimechoDB@2021;

-- 清理数据
drop database test_db;
<<NULL;

--1. 创建数据库
create database test_db;
show databases;

--2. 使用数据库
use test_db;

--3. 创建表
create table t1(
device_id tag,
int32_1 INT32,
int64_1 INT64,
double_1 DOUBLE,
float_1 FLOAT,
boolean_1 BOOLEAN,
text_1 TEXT,
string_1 STRING,
blob_1 BLOB,
object_1 OBJECT,
timestamp_1 TIMESTAMP,
date_1 DATE
);
show tables;
desc t1;

--4. 插入数据
insert into t1
			(time,device_id,int32_1,int64_1,double_1,float_1,boolean_1,text_1,string_1,blob_1,object_1,timestamp_1,date_1)
