	smooth => 0.5,
	threshold => 10.0,
	width => 1000.0, 
	height => 500.0,
	smooth_on_pattern => false
) order by 1,2,3,4;
<<SQLSTATE;

--6.3.12 不存在的列名
select * from pattern_match(
	data => (select time, date_1 from t1 order by time),
	time_col => 'time',
	data_col => 'non_existent_column',
	pattern => '1.0,2.0,3.0',
	smooth => 0.5,
	threshold => 10.0,
	width => 1000.0, 
	height => 500.0,
	smooth_on_pattern => false
) order by 1,2,3,4;
<<SQLSTATE;

--6.4 不同的pattern 长度验证
--6.4.1 pattern对应的列表为空时
select * from pattern_match(
	data => t1, 
	time_col => 'time', 
	data_col => 'int32_1',
	pattern => '',
	smooth => 0.5,
	threshold => 10.0,
	width => 1000.0, 
	height => 500.0,
	smooth_On_Pattern=> false
)order by 1,2,3;
<<SQLSTATE;

--6.4.2 单点pattern测试：为1个时
select * from pattern_match(
	data => t1, 
	time_col => 'time', 
	data_col => 'int32_1',
	pattern => '1',
	smooth => 0.5, 
	threshold => 10.0, 
	width => 1000.0, 
	height => 500.0, 
	smooth_On_Pattern=> false
)order by 1,2,3;
<<SQLSTATE;

--6.4.3 为2个时
select * from pattern_match(
	data => t1, 
	time_col => 'time', 
	data_col => 'int32_1',
	pattern => '1, 2',
