--18. 数据类型OBJECT 不支持INTERSECT
select object_1 from t1
intersect
select object_1 from t2;
<<SQLSTATE;

--19. 列数不匹配
select device_id, int32_1, float_1 from t1
intersect
select device_id, int32_1 from t2;
<<SQLSTATE;

select device_id, int32_1 from t1
intersect
select device_id, int32_1, float_1 from t2;
<<SQLSTATE;

--20. INTERSECT执行多列
select device_id, int32_1, int64_1, double_1, float_1, boolean_1, text_1, string_1, date_1, timestamp_1, blob_1 from t1
intersect 
select device_id, int32_1, int64_1, double_1, float_1, boolean_1, text_1, string_1, date_1, timestamp_1, blob_1 from t2
order by 1, 2, 3, 4;

--21. 子查询作为INTERSECT操作数
select * from (select device_id, int32_1 from t1 where int32_1 < 300) result_1
intersect
select * from (select device_id, int32_1 from t1 where int32_1 < 300) result_2
order by 1, 2;

--22. 带聚合函数COUNT的INTERSECT
select device_id, count(*) as count_result1 from t1 group by device_id 
intersect
select device_id, count(*) as count_result2 from t2 group by device_id
order by device_id;

--23. 含NULL支持的INTERSECT:NULL值被视为相等的
select text_1, string_1 from t1
intersect 
select text_1, string_1 from t2
order by 1,2;

--24. 相同的INTERSECT
select device_id from t1 
intersect
select device_id from t1 
intersect
select device_id from t1
order by device_id;

-- 清理数据
connect root/TimechoDB@2021;
drop database test_db;
<<NULL;
